# Strava — create an app at https://www.strava.com/settings/api
# then complete the OAuth flow to get a refresh token
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Coros — your account credentials for unofficial API sync
COROS_EMAIL=
COROS_PASSWORD=

# Optional: override data directory (defaults to ./data)
# DATA_DIR=/path/to/data
